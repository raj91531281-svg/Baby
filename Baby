<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>For Priyanshi ❤️</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      background: linear-gradient(135deg,#ff4d6d,#111);
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      padding:20px;
      overflow:hidden;
    }

    .card{
      width:100%;
      max-width:400px;
      background:rgba(255,255,255,0.1);
      backdrop-filter:blur(12px);
      border-radius:25px;
      padding:25px;
      text-align:center;
      color:white;
      box-shadow:0 0 25px rgba(0,0,0,0.3);
      animation:float 3s ease-in-out infinite;
    }

    @keyframes float{
      0%{transform:translateY(0px);}
      50%{transform:translateY(-8px);}
      100%{transform:translateY(0px);}
    }

    .profile{
      width:220px;
      height:220px;
      border-radius:20px;
      object-fit:cover;
      border:4px solid white;
      margin-bottom:20px;
    }

    h1{
      font-size:32px;
      margin-bottom:10px;
    }

    p{
      font-size:18px;
      line-height:1.7;
      margin-bottom:20px;
    }

    button{
      padding:14px 28px;
      border:none;
      border-radius:14px;
      background:#ff1744;
      color:white;
      font-size:18px;
      cursor:pointer;
      transition:0.3s;
    }

    button:hover{
      transform:scale(1.08);
    }

    .love{
      position:absolute;
      color:white;
      animation:fall linear infinite;
    }

    @keyframes fall{
      0%{
        transform:translateY(-10vh);
        opacity:1;
      }
      100%{
        transform:translateY(110vh);
        opacity:0;
      }
    }

    audio{
      margin-top:20px;
      width:100%;
    }
  </style>
</head>

<body>

  <div class="card">

    <img src="17060.jpg" class="profile">

    <h1>Priyanshi ❤️</h1>

    <p>
      Distance sirf maps me hota hai...<br>
      Mere dil me toh tum hamesha paas ho ✨<br><br>

      Shayad hum door hain,<br>
      par meri har smile ka reason tum ho 🌸
    </p>

    <button onclick="showLove()">
      Click Me 🥺
    </button>

    <audio controls autoplay loop>
      <source src="kauntujhe.mp3" type="audio/mp3">
    </audio>

  </div>

  <script>
    function showLove(){
      alert("I Love You So Much Priyanshi ❤️");
    }

    for(let i=0;i<30;i++){
      let heart=document.createElement("div");
      heart.innerHTML="❤️";
